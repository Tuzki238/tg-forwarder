# Telegram API credentials from https://my.telegram.org
API_ID=123456
API_HASH=replace_with_your_api_hash

# Keep the session and database in fixed VPS paths.
SESSION_NAME=/opt/tg-forwarder/tg_forwarder
DB_PATH=/opt/tg-forwarder/storage/app.db

# Optional future secrets. Leave unset if the project does not use them.
# BOT_TOKEN=
# DEEPSEEK_API_KEY=
